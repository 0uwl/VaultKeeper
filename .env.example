# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#   docker compose up -d

# CouchDB admin credentials - used by both CouchDB and VaultKeeper
COUCHDB_USER=admin
#COUCHDB_PASSWORD=changeme

# Public-facing CouchDB URL embedded in LiveSync setup URIs.
# For local use, leave this unset or point it at localhost.
# For remote access, set this to the externally reachable URL of CouchDB,
# e.g. https://couchdb.example.com
COUCHDB_PUBLIC_URL=http://localhost:5984

# Secret key used to sign Flask session cookies. Required - the app will not
# start without this. 
# Generate a value with:
#   openssl rand -hex 32
#SECRET_KEY=
